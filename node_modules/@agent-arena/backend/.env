# backend/.env

# Server config
NODE_ENV=development
PORT=3001
WS_PORT=3002

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# Bags API (leave empty for mock mode)
BAGS_API_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PRIVATE_KEY=

# AI APIs (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Feature flags
USE_LLM_DECISIONS=false

# Reward configuration
REWARD_PERCENTAGE=0.01  # 1% of market cap per battle win