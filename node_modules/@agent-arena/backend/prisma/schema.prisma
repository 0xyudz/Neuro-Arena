generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Agent {
  id            String   @id @default(uuid())
  ownerWallet   String
  agentWallet   String   @unique
  tokenSymbol   String
  tokenMint     String
  name          String
  description   String?
  personality   String   @default("balanced")
  strategy      String   @default("balanced")
  imageUrl      String?
  score         Int      @default(100)
  lastAction    String   @default("idle")
  isChampion    Boolean  @default(false)
  price         Float    @default(0.0001)
  marketCap     Float    @default(0)
  priceChange   Float    @default(0)
  holders       Int      @default(0)
  volume24h     Float    @default(0)
  trades        Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  Transaction[]
  battleLogs    BattleLog[]
  
  winStreak     Int      @default(0)
  loseStreak    Int      @default(0)
  recentTrend   String   @default("stable")  // hot | cold | stable
  confidence    Float    @default(0.5)         // 0.0 to 1.0
  wins          Int      @default(0)
  losses        Int      @default(0)

  stakes        Stake[]
  rewards       Reward[]

}

model Transaction {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  type      String
  amount    Float
  price     Float
  timestamp DateTime @default(now())
}

model BattleLog {
  id           String   @id @default(uuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id])
  opponentId   String
  result       String
  scoreChange  Int
  priceChange  Float
  reason       String
  thinkingTrace String? 
  timestamp    DateTime @default(now())

}

// ... existing models ...

// ✅ NEW: Stake model
model Stake {
  id          String   @id @default(cuid())
  userWallet  String
  agentId     String
  amount      Float
  createdAt   DateTime @default(now())
  
  // Relations (optional, for future queries)
  agent       Agent    @relation(fields: [agentId], references: [id])
}

// ✅ NEW: Reward model
model Reward {
  id          String   @id @default(cuid())
  userWallet  String
  agentId     String
  amount      Float
  reason      String?  // "battle_win", "staking_bonus", etc.
  createdAt   DateTime @default(now())
  claimed    Boolean  @default(false)
  claimedAt  DateTime?
  // Relations
  agent       Agent    @relation(fields: [agentId], references: [id])
}